# 32 bytes. Generate: openssl rand -hex 32
APP_ENC_KEY=

# Required for public deployments; if unset, all access is rejected (fail-closed).
DASHBOARD_PASSWORD=

# Falls back to APP_ENC_KEY if unset. Generate: openssl rand -hex 32
AUTH_SECRET=

# NEVER enable in production.
AUTH_DISABLED=false

# Relative to the apps/web working directory
DATABASE_PATH=./data/quota.sqlite

# Seconds. Default 300 (5min), floor 60 (1min).
# The upstream usage endpoints rate-limit (HTTP 429) faster polling; don't go below 60.
POLL_INTERVAL_SECONDS=300

ENABLE_POLLER=true

# ---------------------------------------------------------------------------
# Configuring credentials without the UI (optional)
#
# <PROVIDER> is one of: CLAUDE | CODEX | KIMI | MOONSHOT
#
# A) Inline env vars — seeded into the DB once at startup, then behaves like a
#    UI-entered credential (token refresh persists to the DB). Good for `docker run -e`.
#      QUOTA_<PROVIDER>_BEARERTOKEN=...        # access token / API key
#      QUOTA_<PROVIDER>_REFRESHTOKEN=...       # optional, enables auto-refresh
#      QUOTA_<PROVIDER>_ACCOUNTID=...          # codex: ChatGPT-Account-Id
#      QUOTA_<PROVIDER>_REGION=ai              # moonshot: ai | cn
#      QUOTA_<PROVIDER>_BASEURLOVERRIDE=...    # kimi
#      QUOTA_<PROVIDER>_JSON={"bearerToken":"..."}   # full ProviderCredentials JSON
#      QUOTA_<PROVIDER>_MODE=auto              # auto | api | oauth | web
#      QUOTA_<PROVIDER>_OVERWRITE=false        # true = re-seed from env on every restart
#
# B) Local file source — read fresh on every poll; the file is the source of truth.
#    Point it at the live CLI credential file (mount it read-only into Docker).
#      QUOTA_<PROVIDER>_FILE=/creds/claude/.credentials.json
#      QUOTA_<PROVIDER>_FILE_FORMAT=native     # native (default) | json
#      QUOTA_<PROVIDER>_FILE_WRITABLE=false    # true lets the dashboard refresh + rewrite the file
#
# Read-only (default) is safe: the dashboard never refreshes a read-only file, so it can't
# rotate/invalidate the refresh token that the file's owner (your local CLI) depends on. It just
# re-reads whatever the CLI keeps fresh. Set _FILE_WRITABLE=true (and mount read-write) only when
# the dashboard is the sole refresher — e.g. on a server where the CLI never runs.
#
# Examples:
#   QUOTA_CLAUDE_FILE=/creds/claude/.credentials.json
#   QUOTA_CODEX_FILE=/creds/codex/auth.json
#   QUOTA_KIMI_BEARERTOKEN=sk-...
#   QUOTA_MOONSHOT_BEARERTOKEN=sk-...
