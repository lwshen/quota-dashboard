# 32 bytes. Generate: openssl rand -hex 32
APP_ENC_KEY=

# Required for public deployments; if unset, all access is rejected (fail-closed).
DASHBOARD_PASSWORD=

# Falls back to APP_ENC_KEY if unset. Generate: openssl rand -hex 32
AUTH_SECRET=

# NEVER enable in production.
AUTH_DISABLED=false

# Relative to the apps/web working directory
DATABASE_PATH=./data/quota.sqlite

# Seconds. Default 300 (5min), floor 60 (1min).
# The upstream usage endpoints rate-limit (HTTP 429) faster polling; don't go below 60.
POLL_INTERVAL_SECONDS=300

ENABLE_POLLER=true
